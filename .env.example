# KayaOS v3 — LLM configuration (optional; deterministic mock used otherwise)

# Pick ONE provider:
# OpenRouter (default)
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct

# Or Groq
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# LLM_MODEL=llama-3.3-70b-versatile

# ── Consultation PII encryption ───────────────────────────────────────────────
# 32-byte AES-256-GCM key, base64-encoded. Required in production to encrypt
# raw consultation transcripts and the PII map stored alongside them.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# If unset, a dev-only fallback key is used and a warning is printed at startup.
# PII_ENCRYPTION_KEY=<base64-32-bytes>
